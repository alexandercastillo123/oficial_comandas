# Local SQL Server (Docker) configuration
DB_LOCAL_HOST=la_ideal_sql_local
DB_LOCAL_USER=sa
DB_LOCAL_PASS=SuperSecret123!
DB_LOCAL_NAME=la_ideal_cafeteria

# Cloud SQL Server configuration (optional, fill if you have a cloud instance)
DB_CLOUD_HOST=cloud_sql_server_host
DB_CLOUD_PORT=1433
DB_CLOUD_USER=cloud_user
DB_CLOUD_PASSWORD=CloudSecret123!
DB_CLOUD_NAME=la_ideal_cloud

# Backend server configuration
PORT=3000
HOST=0.0.0.0
API_PORT=3000
JWT_SECRET=UnaClaveMuySeguraYLarga1234567890
ID_TIENDA=2

# Synchronization intervals (ms)
SYNC_DOWN_INTERVAL_MS=1800000   # 30 min
SYNC_UP_INTERVAL_MS=300000      # 5 min (pedidos/comandas)
SYNC_USERS_INTERVAL_MS=900000  # 15 min
MAX_SYNC_RETRIES=5

# Expo (frontend) configuration
EXPO_HOST=0.0.0.0
EXPO_PORT=8082
EXPO_PUBLIC_SUCURSAL_IP=192.168.1.7
